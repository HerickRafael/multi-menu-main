{
  "name": "herickrafel/multi-menu",
  "description": "Multi-menu project",
  "type": "project",
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.88"
  },
  "autoload": {
    "psr-4": {
      "App\\Services\\": "app/services/",
      "App\\Models\\": "app/models/",
      "App\\Controllers\\": "app/controllers/",
      "App\\Middleware\\": "app/middleware/",
      "App\\Repositories\\": "app/Repositories/"
    },
    "classmap": [
      "app/core/",
      "app/config/",
      "app/helpers/",
      "app/services/",
      "app/models/",
      "app/controllers/",
      "app/Repositories/",
      "app/middleware/"
    ],
    "files": [
      "app/config/FormatConstants.php",
      "app/helpers/MoneyFormatter.php",
      "app/helpers/ReceiptFormatter.php",
      "app/helpers/TextParser.php",
      "app/helpers/JsonHelper.php",
      "app/helpers/DataValidator.php",
      "app/helpers/xss_helper.php",
      "app/middleware/RateLimiter.php",
      "app/middleware/CsrfProtection.php",
      "app/middleware/SecurityHeaders.php",
      "app/middleware/SqlInjectionPrevention.php",
      "app/middleware/XssProtection.php",
      "app/middleware/InputValidator.php",
      "app/middleware/AuthenticationSystem.php",
      "app/middleware/Authorization.php",
      "app/middleware/ApiSecurity.php",
      "app/middleware/FileUploadSecurity.php",
      "app/middleware/AuditLogger.php",
      "app/middleware/EncryptionLayer.php",
      "app/middleware/SecurityMonitoring.php"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "innovation-studios/evolution-api-plugin": "^1.0",
    "setasign/fpdf": "^1.8",
    "predis/predis": "^3.2",
    "minishlink/web-push": "^10.0"
  }
}
